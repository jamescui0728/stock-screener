backend/user_settings.json

# ── Python ────────────────────────────────────────
backend/.venv/
backend/venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ── Node / 前端 ───────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.parcel-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── 编辑器 / OS ───────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 日志 / 临时 ───────────────────────────────────
*.log
*.tmp
*.bak
/tmp/

# ── Docker 相关临时 ───────────────────────────────
docker-compose.override.yml
