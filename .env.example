# 复制本文件为 .env 后修改
#   cp .env.example .env
#
# docker compose 启动时会自动加载 .env 里的变量

# ─── JWT 签名密钥（必改）─────────────────────────────
# 生产部署务必生成强随机值，例如：
#   openssl rand -base64 48
# 或 Python：
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET=change-me-in-production-this-should-be-random-and-long

# ─── 暴露给宿主机的 HTTP 端口 ────────────────────────
# 浏览器访问 http://localhost:${HTTP_PORT}
HTTP_PORT=8080
